# ============================================
# DHANTI Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in values
# cp .env.example .env

# ----- App -----
APP_NAME=DHANTI
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000

# ----- PostgreSQL (Neon) -----
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxxx.region.aws.neon.tech/dhanti?sslmode=require

# ----- Supabase Storage -----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_BUCKET=dhanti-files

# ----- Upstash Redis -----
REDIS_URL=rediss://default:your-password@your-endpoint.upstash.io:6379

# ----- Gemini (default/primary LLM Provider) -----
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxx
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_DEFAULT_MODEL=gemini-2.5-flash

# ----- GLM (additional selectable LLM Provider — not in the default fallback chain) -----
GLM_API_KEY=xxxxxxxxxxxxxxxxxxxx
GLM_BASE_URL=https://api.z.ai/api/paas/v4
GLM_DEFAULT_MODEL=glm-5.2

# ----- OpenRouter (selectable LLM Provider) -----
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=qwen/qwen3-235b-a22b

# ----- Groq (fallback LLM Provider, used when the primary is rate-limited/out of credits) -----
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_DEFAULT_MODEL=qwen/qwen3-32b

# ----- Hugging Face (Embedding Provider) -----
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxx
HF_EMBEDDING_MODEL=BAAI/bge-m3
HF_INFERENCE_URL=https://router.huggingface.co/hf-inference

# ----- Qdrant Cloud (Vector DB) -----
QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333
QDRANT_API_KEY=xxxxxxxxxxxxxxxxxxxx
QDRANT_COLLECTION=dhanti_vectors

# ----- File Upload Limits -----
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=csv,xlsx,xls,pdf

# ----- AI Settings -----
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7
AI_CONTEXT_TOKEN_BUDGET=8000
AI_EXECUTION_TIMEOUT_SECONDS=120
